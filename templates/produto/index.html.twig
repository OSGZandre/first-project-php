{% extends 'base.html.twig' %}
{% block title %}Hello ProdutoController!{% endblock %}

{% block body %}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code {padding: 2px 6px; }
</style>
    <div class="example-wrapper">
    <h1>Cadastro de Produto</h1>

        {{ form_start(form) }}
            {{ form_widget(form) }}
            <button class="btn btn-outline-success">
                {% if app.request.get('id') %}
                    Atualizar
                {% else %}
                    Salvar
                {% endif %}
            </button>
        {{ form_end(form) }}
    </div>
        <hr>

        <h2>Produtos cadastrados</h2>
        <table class="table">
            <tr>
                <th>ID</th>
                <th>Nome</th>
                <th>Preço</th>
                <th>Estoque</th>
                <th>Ações</th>
            </tr>
            {% for p in produtos %}
                <tr>
                    <td>{{ p.idProduto }}</td>
                    <td>{{ p.nameProduto }}</td>
                    <td>{{ p.preco }}</td>
                    <td>{{ p.estoque }}</td>
                    <td>
                        <a href="{{ path('produto_novo', {idProduto: p.idProduto}) }}" class="btn btn-outline-warning btn-sm">Editar</a>
                        <a href="{{ path('produto_delete', {idProduto: p.idProduto}) }}" class="btn btn-outline-danger btn-sm">Remover</a>
                    </td>
                </tr>
            {% endfor %}
        </table>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
{% endblock %}
