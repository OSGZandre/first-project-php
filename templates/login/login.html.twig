
{% block title %}Login{% endblock %}
{% block body %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <style>
        .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
        .example-wrapper code { padding: 2px 6px; }
    </style>

    <div class="example-wrapper">
        <h1>Login</h1> <br />
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}
        <form action="{{ path('app_login') }}" method="post">
            <div>
                <label class="form-label">Email</label>
                <input type="email" class="form-control" name="email" placeholder="Digite seu Email" required /> <br />
                <label class="form-label">Senha</label>
                <input type="password" class="form-control" name="password" placeholder="Digite sua senha" required /> <br />
                <button class="btn btn-outline-success" type="submit">Entrar</button>
            </div>
        </form>
        <p>Não tem uma conta? <a href="{{ path('app_lucky_number') }}">Cadastre-se</a></p>
        {% if app.session.get('auth_token') %}
            <script>
                localStorage.setItem('auth_token', '{{ app.session.get('auth_token') }}');
            </script>
        {% endif %}
    </div>
{% endblock %}